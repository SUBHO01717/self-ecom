# Environment Variables Template - Daily Essentials E-commerce
# Copy this file to .env and fill in your actual values for production

# ============================================================================
# DJANGO CORE SETTINGS
# ============================================================================

# Set to False in production!
DEBUG=True

# Django settings module (change to settings_production for production)
DJANGO_SETTINGS_MODULE=daily_essentials.settings

# Generate a random SECRET_KEY:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me

# ============================================================================
# ALLOWED HOSTS & SECURITY
# ============================================================================

# Comma-separated list of domains (localhost for development)
ALLOWED_HOSTS=127.0.0.1,localhost

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# For production: PostgreSQL is recommended
# DATABASE_URL=postgresql://de_user:password@localhost:5432/daily_essentials

# ============================================================================
# REDIS CACHE CONFIGURATION (Optional, for production)
# ============================================================================

# Redis connection string
# REDIS_URL=redis://localhost:6379/1

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# Gmail SMTP
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

DEFAULT_FROM_EMAIL=Daily Essentials <noreply@example.com>

# ============================================================================
# ANALYTICS & TRACKING
# ============================================================================

# Google Analytics
# GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Facebook Pixel
# FACEBOOK_PIXEL_ID=your-pixel-id

# ============================================================================
# ERROR TRACKING (Optional)
# ============================================================================

# Sentry error tracking (production only)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# ============================================================================
# AWS S3 CONFIGURATION (Optional)
# ============================================================================

# For storing media files in S3 instead of local storage
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1

# ============================================================================
# SOCIAL MEDIA LINKS
# ============================================================================

# FACEBOOK_PAGE_URL=https://www.facebook.com/yourbusiness
# INSTAGRAM_URL=https://www.instagram.com/yourbusiness
# WHATSAPP_NUMBER=+8801717081227

# ============================================================================
# PRODUCTION CHECKLIST
# ============================================================================

# For production deployment:
# 1. Set DEBUG=False
# 2. Set DJANGO_SETTINGS_MODULE=daily_essentials.settings_production
# 3. Generate new SECRET_KEY
# 4. Configure DATABASE_URL with PostgreSQL
# 5. Configure REDIS_URL
# 6. Configure EMAIL settings
# 7. Set ALLOWED_HOSTS to your domain names
# 8. Keep this .env file secure (chmod 600)

